<div class="custom-theme-home" data-custom-theme-home>
  {{#if (theme-setting "announcement_text")}}
    <div class="custom-theme-announcement" role="status">
      {{theme-setting "announcement_text"}}
    </div>
  {{/if}}

  {{#if (theme-setting "show_homepage_hero")}}
    <section class="custom-theme-banner" aria-labelledby="custom-theme-banner-title">
      <div class="custom-theme-banner__content">
        <p class="custom-theme-banner__eyebrow">
          {{theme-setting "hero_eyebrow"}}
        </p>
        <h1 class="custom-theme-banner__title" id="custom-theme-banner-title">
          {{theme-setting "hero_title"}}
        </h1>
        <p class="custom-theme-banner__description">
          {{theme-setting "hero_subtitle"}}
        </p>
      </div>

      <div class="custom-theme-banner__actions">
        <a
          class="custom-theme-button custom-theme-button--primary"
          href={{theme-setting "hero_cta_url"}}
        >
          {{theme-setting "hero_cta_text"}}
        </a>
        <a
          class="custom-theme-button custom-theme-button--secondary"
          href={{theme-setting "hero_secondary_cta_url"}}
        >
          {{theme-setting "hero_secondary_cta_text"}}
        </a>
      </div>
    </section>
  {{/if}}

  {{#if (theme-setting "show_quick_links")}}
    <nav class="custom-quick-links" aria-label="Featured forum links">
      <a class="custom-quick-link" href={{theme-setting "quick_link_1_url"}}>
        <span class="custom-quick-link__label">
          {{theme-setting "quick_link_1_label"}}
        </span>
        <span class="custom-quick-link__text">
          {{theme-setting "quick_link_1_text"}}
        </span>
      </a>
      <a class="custom-quick-link" href={{theme-setting "quick_link_2_url"}}>
        <span class="custom-quick-link__label">
          {{theme-setting "quick_link_2_label"}}
        </span>
        <span class="custom-quick-link__text">
          {{theme-setting "quick_link_2_text"}}
        </span>
      </a>
      <a class="custom-quick-link" href={{theme-setting "quick_link_3_url"}}>
        <span class="custom-quick-link__label">
          {{theme-setting "quick_link_3_label"}}
        </span>
        <span class="custom-quick-link__text">
          {{theme-setting "quick_link_3_text"}}
        </span>
      </a>
    </nav>
  {{/if}}
</div>
